# ============================================================
# CodePath environment variables
# ============================================================
# Copy this file to .env (or .env.local) and fill in real values.
# Variables must be prefixed with VITE_ to be exposed to the browser.

# === Supabase (optional — app works without these in localStorage-only mode) ===
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# === Anthropic API (optional — for AI Explainer feature) ===
# Users can also provide their own key via the UI. This is just a fallback.
# Get yours from: https://console.anthropic.com/settings/keys
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# After editing this file:
#   1. Save as `.env` in the project root (DO NOT commit .env)
#   2. Restart the dev server: npm run dev
# ============================================================
